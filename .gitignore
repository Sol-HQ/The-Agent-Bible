# ──────────────────────────────────────────────────────────────────────────────
# .gitignore — The Agent Bible
# ──────────────────────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
.eggs/
wheels/
*.whl
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example

# Test / coverage artefacts
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py,cover
nosetests.xml
test-results/

# Type-checker caches
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter / IPython
.ipynb_checkpoints/
*.ipynb

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.code-workspace

# Secrets & credentials
*.pem
*.key
*.cert
*.p12
secrets.json
credentials.json
service_account*.json

# Logs
*.log
logs/

# Temporary / scratch files
tmp/
temp/
scratch/

# Agent memory / local state databases
.chroma/
*.sqlite
*.sqlite3
*.db
agent_memory/
brain-material/
models/
implementations/local-sovereign-agent/models/
